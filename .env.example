# ──────────────────────────────────────────────────────────────────────────────
# Apalabrazos — Variables de entorno
#
# Copiá este archivo a .env y completá los valores.
# NUNCA subas el .env al repositorio.
# ──────────────────────────────────────────────────────────────────────────────


# ── JWT ───────────────────────────────────────────────────────────────────────
# Clave secreta para firmar los tokens. Usá una cadena larga y aleatoria.
JWT_SECRET=cambia_esto_por_un_secreto_seguro

# Issuer y audience que se incluyen en el payload del token.
JWT_ISSUER=apalabrazos
JWT_AUDIENCE=apalabrazos-client

# Duración del token en minutos. (por defecto: 120)
JWT_EXP_MINUTES=120


# ── Azure Cosmos DB ───────────────────────────────────────────────────────────
# Endpoint y clave de acceso de tu cuenta Cosmos DB.
COSMOS_DB_ENDPOINT=https://tu-cuenta.documents.azure.com:443/
COSMOS_DB_KEY=tu_clave_primaria_de_cosmos_db

# Nombre de la base de datos y el contenedor de preguntas.
COSMOS_DB_DATABASE=apalabrazos
COSMOS_DB_QUESTIONS_CONTAINER=Questions


# ── IA — Generación de preguntas ──────────────────────────────────────────────
# URL del endpoint LLM (Ollama, Anthropic-compatible, etc.)
AI_API_URL=http://localhost:11434/api/chat

# API key del proveedor. Dejá vacío si el endpoint no requiere autenticación.
AI_API_KEY=

# Modelo principal y modelo de fallback (usado si el principal devuelve 503).
AI_MODEL=gemma3:4b
AI_FALLBACK_MODEL=

# Parámetros de generación. Los valores por defecto funcionan para la mayoría de casos.
AI_QUESTIONS_PER_LETTER=1
AI_QUESTIONS_TO_GENERATE_PER_LETTER_IN_BATCH=2
AI_LETTERS_PER_BATCH=25
AI_MAX_ATTEMPTS_PER_BATCH=1
AI_MAX_TOKENS=2000


# ── Aplicación ────────────────────────────────────────────────────────────────
# Nombre y URL inyectados en los prompts de IA.
AI_APP_NAME=Apalabrazos
AI_APP_URL=https://github.com/trutoman/Apalabrazos

# Seeding inicial de preguntas en Cosmos DB al arrancar (true/false).
SEED_QUESTIONS_ON_START=false
QUESTIONS_SEED_FILE=classpath:/Apalabrazos/data/questions2.json

# Opciones extra para la JVM (ej: -Xmx512m). Dejá vacío para usar los defaults.
JAVA_OPTS=
